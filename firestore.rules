rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email == "flosnidor9@gmail.com";
    }

    function isString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    match /guestbook/{entry} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasOnly(["name", "message", "timestamp"])
        && isString(request.resource.data.name, 0, 50)
        && isString(request.resource.data.message, 1, 500)
        && request.resource.data.timestamp == request.time;

      allow update, delete: if false;
    }

    match /logs/{logId} {
      allow read: if true;

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly(["title", "content", "tags", "images", "timestamp", "year"])
        && (!request.resource.data.keys().hasAny(["title"]) || isString(request.resource.data.title, 1, 120))
        && isString(request.resource.data.content, 1, 10000)
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 10
        && request.resource.data.images is list
        && request.resource.data.images.size() <= 12
        && request.resource.data.timestamp == request.time
        && request.resource.data.year is int
        && request.resource.data.year >= 2020
        && request.resource.data.year <= 2100;

      allow update, delete: if isAdmin();
    }

    match /logPostComments/{postSlug}/comments/{commentId} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasOnly(["author", "content", "createdAt"])
        && isString(request.resource.data.author, 1, 24)
        && isString(request.resource.data.content, 1, 500)
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }
  }
}
